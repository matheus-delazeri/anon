generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserGroup {
  user_id  Int
  group_id Int

  user  User  @relation(fields: [user_id], references: [id])
  group Group @relation(fields: [group_id], references: [id])

  role Role @default(NORMAL)

  @@id([user_id, group_id])
}

model Group {
  id               Int         @id @default(autoincrement())
  name             String
  master           User        @relation("MasterRelation",fields: [masterId], references: [id])
  masterId         Int
  isModerator      Boolean
  moderator        User?       @relation("ModeratorRelation",fields: [moderatorId], references: [id])
  moderatorId      Int?
  created_at       DateTime
  UserGroup        UserGroup[]
}

model User {
  id               Int         @id @default(autoincrement())
  hash             String      @unique
  created_at       DateTime
  UserGroup        UserGroup[]
  masterOf         Group[]     @relation("MasterRelation")
  moderatorOf      Group[]     @relation("ModeratorRelation")
}

enum Role {
  ADMIN
  NORMAL
  MODERATOR
}
